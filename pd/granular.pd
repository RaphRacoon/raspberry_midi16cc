#N canvas 0 0 600 500 BUFFER-MANAGER 12;
#X text 5 5 Buffer 2 sec @ 44100 = 88200 samples;
#X obj 10 30 table grain-buf 88200;
#X obj 10 80 r record-trig;
#X obj 10 110 * 0.007874;
#X obj 10 140 > 63;
#X obj 10 170 sel 1;
#X obj 10 200 metro 1;
#X obj 120 200 metro 1;
#X obj 10 230 f 0;
#X obj 10 260 + 1;
#X obj 10 290 mod 88200;
#X obj 120 230 f 0;
#X obj 120 260 + 1;
#X obj 120 290 mod 88200;
#X obj 10 320 adc~;
#X obj 10 350 tabwrite~ grain-buf;
#X obj 10 380 r freeze;
#X obj 10 410 * 0.007874;
#X obj 10 440 > 63;
#X obj 10 470 sel 1;
#X obj 10 500 metro 0;
#X connect 2 0 3 0;
#X connect 3 0 4 0;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 8 0;
#X connect 8 0 9 0;
#X connect 9 0 10 0;
#X connect 10 0 8 0;
#X connect 10 0 15 1;
#X connect 14 0 15 0;
#X restore 10 100 pd BUFFER-MANAGER;

